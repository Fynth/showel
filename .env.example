# Shovel Environment Configuration
# Copy this file to .env and fill in your values

# DeepSeek API Configuration (for embedded ACP agent)
# DEEPSEEK_API_KEY=your_api_key_here
# DEEPSEEK_BASE_URL=https://api.deepseek.com
# DEEPSEEK_MODEL=deepseek-reasoner

# CodeStral API Configuration (for inline completions)
# CODESTRAL_API_KEY=your_api_key_here
# CODESTRAL_BASE_URL=https://codestral.example.com

# Logging
# RUST_LOG=info
